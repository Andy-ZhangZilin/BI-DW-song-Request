# outdoor-data-validator 凭证模板
# 复制此文件为 .env 并填入真实凭证：cp .env.example .env
#
# 警告：请勿在此文件中填入真实凭证，.env.example 会提交至 Git
# 真实凭证只能写入 .env（已在 .gitignore 中排除）

# TripleWhale
TRIPLEWHALE_API_KEY=

# TikTok Shop（凭证从 DTC Hub 获取）
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
# TikTok Shop API 路径参数（用于含动态 ID 的接口，填入示例值即可）
TIKTOK_PRODUCT_ID=       # 用于 shop_product_performance / affiliate_sample_status / affiliate_campaign_performance
TIKTOK_CAMPAIGN_ID=      # 用于 affiliate_sample_status / affiliate_campaign_performance
TIKTOK_CREATOR_TEMP_ID=  # 用于 affiliate_sample_status

# 钉钉多维表
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_WORKBOOK_ID=        # 必填：多维表 workbook ID（URL 中的 spaceId）
DINGTALK_SHEET_ID=           # 可选：指定 sheet ID；留空时自动取第一个 Sheet

# YouTube
YOUTUBE_API_KEY=

# Awin（账号密码登录）
AWIN_USERNAME=
AWIN_PASSWORD=

# CartSee（账号密码登录）
CARTSEE_USERNAME=
CARTSEE_PASSWORD=

# PartnerBoost（账号密码登录）
PARTNERBOOST_USERNAME=
PARTNERBOOST_PASSWORD=

# Facebook Business Suite（账号密码登录，Playwright 爬虫）
FACEBOOK_USERNAME=
FACEBOOK_PASSWORD=

# YouTube Studio（Google 账号登录，Playwright 爬虫；需关闭两步验证）
YOUTUBE_STUDIO_EMAIL=
YOUTUBE_STUDIO_PASSWORD=
