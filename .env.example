# outdoor-data-validator 凭证模板
# 复制此文件为 .env 并填入真实凭证：cp .env.example .env
#
# 警告：请勿在此文件中填入真实凭证，.env.example 会提交至 Git
# 真实凭证只能写入 .env（已在 .gitignore 中排除）

# TripleWhale
TRIPLEWHALE_API_KEY=

# TikTok Shop（DTC Hub 中获取 refresh_token，手动填入）
TIKTOK_REFRESH_TOKEN=
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=

# 钉钉多维表
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=

# YouTube
YOUTUBE_API_KEY=

# Awin（账号密码登录）
AWIN_USERNAME=
AWIN_PASSWORD=

# CartSee（账号密码登录）
CARTSEE_USERNAME=
CARTSEE_PASSWORD=

# PartnerBoost（账号密码登录）
PARTNERBOOST_USERNAME=
PARTNERBOOST_PASSWORD=
